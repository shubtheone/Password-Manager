# Copy this file to .env and edit as needed. All variables are optional.

# Port the server listens on (default: 3000)
# PORT=3000

# Secret for signing session cookies. Set a fixed value so sessions survive restarts.
# SESSION_SECRET=your-random-secret-here

# If set, enables the dev-only "reset profile" endpoint for forgotten keywords.
# Leave unset (or omit) to disable recovery; the reset route will not be registered.
DEV_RECOVERY_SECRET=mysecretpassword
